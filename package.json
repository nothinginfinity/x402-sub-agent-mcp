{
  "name": "x402-sub-agent-mcp",
  "version": "0.1.0",
  "description": "AFO sub-agent MCP: x402 payment policy engine (coupons, enterprise tiers, internal tokens, protected-route rules).",
  "type": "module",
  "main": "worker.js",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "check": "node --check worker.js",
    "db:migrate:local": "wrangler d1 execute x402-sub-agent-db --local --file=migrations/0001_initial.sql",
    "db:migrate:remote": "wrangler d1 execute x402-sub-agent-db --remote --file=migrations/0001_initial.sql"
  },
  "devDependencies": {
    "wrangler": "^4"
  }
}
